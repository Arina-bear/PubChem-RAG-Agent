APP_NAME=PubChem Compound Explorer API
API_VERSION=0.1.0
ENVIRONMENT=development

PUBCHEM_REST_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug
PUBCHEM_VIEW_BASE_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug_view

REQUEST_TIMEOUT_SECONDS=15
LLM_REQUEST_TIMEOUT_SECONDS=45
MAX_RETRIES=3
CANDIDATE_LIMIT=10
QUERY_RATE_LIMIT_PER_SECOND=3
LLM_RATE_LIMIT_PER_SECOND=2
HEAVY_QUERY_CONCURRENCY=1
AGENT_MAX_STEPS=6

LLM_DEFAULT_PROVIDER=modal_glm

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

MODAL_GLM_BASE_URL=https://api.us-west-2.modal.direct/v1
MODAL_GLM_API_KEY=
MODAL_GLM_MODEL=zai-org/GLM-5-FP8
MODAL_GLM_DISABLE_THINKING=true

FRONTEND_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
